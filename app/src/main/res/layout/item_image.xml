<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="130dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/ivThumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Page image" />

    <!-- Dark scrim at top for badges readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#66000000" />

    <!-- Page number badge (top-left) -->
    <TextView
        android:id="@+id/tvPageNumber"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="top|start"
        android:layout_margin="5dp"
        android:background="@drawable/badge_bg"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:text="1" />

    <!-- Drag handle (top-right) — user touches this to drag -->
    <ImageView
        android:id="@+id/ivDragHandle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_margin="5dp"
        android:src="@drawable/ic_drag_handle"
        android:contentDescription="Drag to reorder"
        android:padding="4dp" />

    <!-- Long-press hint at bottom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#88000000"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:text="Hold to delete"
        android:textColor="#CCFFFFFF"
        android:textSize="9sp"
        android:gravity="center" />

</androidx.cardview.widget.CardView>
